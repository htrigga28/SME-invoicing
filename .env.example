# Shared
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_replace_me

# Backend
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/sme_invoicing_dev"
TEST_DATABASE_URL="postgresql://<user>:<password>@localhost:5432/sme_invoicing_test"
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
PAYSTACK_SECRET_KEY=sk_test_replace_me
PAYSTACK_WEBHOOK_SECRET=replace_me_webhook_secret
FRONTEND_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Later integrations
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
BREVO_API_KEY=
BREVO_SENDER_EMAIL=

# If local PostgreSQL uses peer/trust authentication, DATABASE_URL can omit the password:
# DATABASE_URL="postgresql://<user>@localhost:5432/sme_invoicing_dev"
# TEST_DATABASE_URL="postgresql://<user>@localhost:5432/sme_invoicing_test"
