{
  "name": "sme-invoicing",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @sme-invoicing/api db:generate",
    "db:migrate": "pnpm --filter @sme-invoicing/api db:migrate",
    "db:studio": "pnpm --filter @sme-invoicing/api db:studio",
    "db:push": "pnpm --filter @sme-invoicing/api db:push",
    "db:test:migrate": "pnpm --filter @sme-invoicing/api db:test:migrate",
    "db:seed": "pnpm --filter @sme-invoicing/api db:seed",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
